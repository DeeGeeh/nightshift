# ─── Required ─────────────────────────────────────────────────────────
LINEAR_API_KEY=lin_api_...
GITHUB_TOKEN=ghp_...
REPO_PATH=/home/youruser/your-product-repo

# ─── Linear ──────────────────────────────────────────────────────────
LINEAR_TEAM_KEY=ENG              # Filter to a specific team (omit for all)
RETRIAGE=false                   # Re-process already-labeled issues

# ─── Schedule ────────────────────────────────────────────────────────
SHIFT_START=18                   # Hour shift begins (24h, default 18 = 6 PM)
SHIFT_STOP=5                     # Hour shift ends (default 5 AM)
POLL_INTERVAL_MS=60000           # Check Linear every N ms (default 1 min)

# ─── Git ─────────────────────────────────────────────────────────────
DEFAULT_BRANCH=main
BRANCH_PREFIX=autofix/           # e.g. autofix/abc-123

# ─── Agent ───────────────────────────────────────────────────────────
AGENT_TIMEOUT_MS=1800000         # Max time per ticket (default 30 min)
MAX_CONCURRENT=1                 # Tickets worked on simultaneously

# ─── CI Gate ────────────────────────────────────────────────────────
CI_TIMEOUT_MS=600000             # Max wait for CI checks (default 10 min)
MAX_CI_RETRIES=2                 # CI fix attempts before giving up

# ─── Idle Cleanup ────────────────────────────────────────────────────
CLEANUP_ENABLED=true             # DRY refactoring during idle time
CLEANUP_COOLDOWN_MS=3600000      # Min time between cleanup runs (default 1 hr)
CLEANUP_BRANCH_PREFIX=cleanup/   # e.g. cleanup/dry-m3k7x

# ─── Misc ────────────────────────────────────────────────────────────
CONTEXT7_API_KEY=                # Optional Context7 MCP key (falls back to npx)
SEEN_FILE=./seen-issues.json     # Tracks already-processed issues
SEEN_COMMENTS_FILE=./seen-comments.json  # Tracks processed PR review comments
DRY_RUN=false                    # Log actions without doing them
FORCE_ISSUE=                     # Process a single issue then exit (e.g. ABC-123)
ONCE=false                       # Run one poll cycle then exit (or --once flag)
